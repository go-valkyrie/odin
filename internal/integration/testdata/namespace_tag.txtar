# Test --namespace flag exposes namespace as a CUE tag for explicit use in bundles

odin-setup
exec odin cue mod tidy
exec odin template --namespace my-namespace
cmp stdout expected.yaml

-- cue.mod/module.cue --
module: "test.example.com/namespace-tag@v0"
language: version: "v0.14.0"
deps: {
    "go-valkyrie.com/odin/api@v0": {
        v: "v0.0.1"
    }
}

-- bundle.cue --
package bundle

import odin "go-valkyrie.com/odin/api/v1alpha1"

odin.#Bundle & {
    metadata: name: "namespace-tag"

    components: {
        myapp: odin.#Component & {
            metadata: name: "myapp"
            config: {}
            resources: {
                configmap: {
                    apiVersion: "v1"
                    kind:       "ConfigMap"
                    metadata: {
                        name:      "myapp"
                        namespace: string @tag(namespace)
                    }
                    data: key: "value"
                }
            }
        }
    }

    values: components: {}
}

-- expected.yaml --
# myapp.configmap
apiVersion: v1
data:
  key: value
kind: ConfigMap
metadata:
  name: myapp
  namespace: my-namespace
