# Test that passing --namespace to a compat 1 bundle that does NOT use @tag(namespace, var=namespace)
# succeeds without error — TagVars silently ignores unreferenced vars.

odin-setup
exec odin cue mod tidy
exec odin template --namespace my-namespace
cmp stdout expected.yaml

-- odin.toml --
compat = 1

-- cue.mod/module.cue --
module: "test.example.com/namespace-compat1-no-tag@v0"
language: version: "v0.14.0"
deps: {
    "go-valkyrie.com/odin/api@v0": {
        v: "v0.0.1"
    }
}

-- bundle.cue --
package bundle

import odin "go-valkyrie.com/odin/api/v1alpha1"

odin.#Bundle & {
    metadata: name: "namespace-compat1-no-tag"

    components: {
        myapp: odin.#Component & {
            metadata: name: "myapp"
            config: {}
            resources: {
                configmap: {
                    apiVersion: "v1"
                    kind:       "ConfigMap"
                    metadata: name: "myapp"
                    data: key: "value"
                }
            }
        }
    }

    values: components: {}
}

-- expected.yaml --
# myapp.configmap
apiVersion: v1
data:
  key: value
kind: ConfigMap
metadata:
  name: myapp
